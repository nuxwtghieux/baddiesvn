--// REMOTE
local snowRemote = Net:FindFirstChild("RE/snowballLauncherFire")

--// STATE
local SelectedTarget = nil

--// TOOLS
local VALID_TOOLS = {
	["Snowball Launcher"] = true,
	["Golden Snowball Launcher"] = true
}

--// SAFE EQUIP
local function safeEquip(tool)
	local char = player.Character
	if not char or not tool then return end

	local hum = char:FindFirstChildOfClass("Humanoid")
	if hum then
		hum:UnequipTools()
	end

	task.wait()
	tool.Parent = char
	task.wait(0.03)
end

--// LẤY TẤT CẢ SÚNG (CẢ 2)
local function getAllSnowTools()
	local char = player.Character
	local backpack = player:FindFirstChild("Backpack")
	local tools = {}
	
	if char then
		for _, v in pairs(char:GetChildren()) do
			if v:IsA("Tool") and VALID_TOOLS[v.Name] then
				table.insert(tools, v)
			end
		end
	end
	
	if backpack then
		for _, v in pairs(backpack:GetChildren()) do
			if v:IsA("Tool") and VALID_TOOLS[v.Name] then
				table.insert(tools, v)
			end
		end
	end
	
	return tools
end

--// HÀM BẮN 1 PHÁT (KHÔNG CẦN BIẾT SÚNG GÌ)
local function fireAtTarget()
	local char = player.Character
	if not char or not SelectedTarget then return end
	
	local targetChar = SelectedTarget.Character
	if not targetChar then return end
	
	local hrp = targetChar:FindFirstChild("HumanoidRootPart")
	if not hrp or not snowRemote then return end
	
	local origin = char.Head.Position
	local velocity = hrp.Velocity
	local distance = (hrp.Position - origin).Magnitude
	local predictTime = math.clamp(distance / 120, 0.08, 0.25)
	
	local predictedPos
	local toTarget = (hrp.Position - origin).Unit
	local speed = velocity.Magnitude
	
	if speed < 2 then
		predictedPos = hrp.Position
	else
		local moveDir = velocity.Unit
		local sideFactor = 1 - math.abs(toTarget:Dot(moveDir))
		local leadMultiplier = 1 + (sideFactor * 2)
		predictedPos = hrp.Position + (velocity * predictTime * leadMultiplier)
	end
	
	if math.abs(velocity.Y) > 2 then
		local airTime = math.clamp(predictTime * 1.2, 0.1, 0.35)
		predictedPos = predictedPos + Vector3.new(0, velocity.Y * airTime, 0)
	end
	
	predictedPos = Vector3.new(
		predictedPos.X,
		math.min(predictedPos.Y, hrp.Position.Y),
		predictedPos.Z
	)
	
	local OFFSET_Y = 2.2
	local targetPos = predictedPos - Vector3.new(0, OFFSET_Y, 0)
	local direction = (targetPos - origin).Unit
	
	pcall(function()
		snowRemote:FireServer(origin, direction, targetPos)
	end)
end


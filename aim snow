--------------------------------------------------
-- TARGET LIST
--------------------------------------------------
local ListFrame = Instance.new("Frame",ScreenGui)
ListFrame.Size = UDim2.new(0,200,0,160)
ListFrame.Position = Main.Position + UDim2.new(0,45,0,45)
ListFrame.BackgroundColor3 = Color3.fromRGB(0,0,0)
ListFrame.BackgroundTransparency = 0.3
ListFrame.Visible = false
Instance.new("UICorner",ListFrame)

local Scroll = Instance.new("ScrollingFrame",ListFrame)
Scroll.Size = UDim2.new(1,0,1,0)
Scroll.BackgroundTransparency = 1
Scroll.ScrollBarThickness = 4

local UIList = Instance.new("UIListLayout",Scroll)
UIList.Padding = UDim.new(0,5)

local function refreshList()
	for _,v in pairs(Scroll:GetChildren()) do
		if v:IsA("TextButton") then v:Destroy() end
	end

	for _,plr in pairs(Players:GetPlayers()) do
		if plr ~= player then
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1,-10,0,30)
			btn.BackgroundColor3 = Color3.fromRGB(20,20,20)
			btn.TextColor3 = Color3.new(1,1,1)
			btn.Font = Enum.Font.Gotham
			btn.TextSize = 12
			btn.Text = plr.DisplayName
			btn.Parent = Scroll

			Instance.new("UICorner",btn)

			btn.MouseButton1Click:Connect(function()
				SelectedTarget = plr
				TargetButton.Text = plr.DisplayName
				ListFrame.Visible = false
			end)
		end
	end

	task.wait()
	Scroll.CanvasSize = UDim2.new(0,0,0,UIList.AbsoluteContentSize.Y)
end

TargetButton.MouseButton1Click:Connect(function()
	ListFrame.Visible = not ListFrame.Visible
	if ListFrame.Visible then refreshList() end
end)

--------------------------------------------------
-- DRAG UI
--------------------------------------------------
local dragging=false
local dragInput,dragStart,startPos

Main.InputBegan:Connect(function(input)
	if input.UserInputType==Enum.UserInputType.MouseButton1 then
		dragging=true
		dragInput=input
		dragStart=input.Position
		startPos=Main.Position

		input.Changed:Connect(function()
			if input.UserInputState==Enum.UserInputState.End then
				dragging=false
			end
		end)
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and input==dragInput then
		local delta=input.Position-dragStart

		Main.Position=UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset+delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset+delta.Y
		)

		ListFrame.Position = Main.Position + UDim2.new(0,45,0,45)
	end
end)

--------------------------------------------------
-- 🔥 MAIN SHOOT (FINAL)
--------------------------------------------------
Toggle.MouseButton1Click:Connect(function()

	Toggle.Text="..."

	local char=player.Character
	if not char or not SelectedTarget then
		Toggle.Text="ON"
		return
	end

	-- SAVE OLD TOOL
	local oldTool=char:FindFirstChildOfClass("Tool")

	local targetChar=SelectedTarget.Character
	local hrp=targetChar and targetChar:FindFirstChild("HumanoidRootPart")
	if not hrp then
		Toggle.Text="ON"
		return
	end

	local tools=getAllSnow()

	for _,tool in ipairs(tools) do

		safeEquip(tool)
		task.wait(0.06)

		local origin=char.Head.Position
		local velocity=hrp.Velocity
		local distance=(hrp.Position-origin).Magnitude
		local predictTime=math.clamp(distance/120,0.08,0.25)

		local predictedPos=hrp.Position+(velocity*predictTime)

		local targetPos=predictedPos-Vector3.new(0,2.2,0)
		local direction=(targetPos-origin).Unit

		pcall(function()
			snowRemote:FireServer(origin,direction,targetPos)
		end)

		task.wait(0.08)
	end

	-- RETURN OLD TOOL
	if oldTool then
		safeEquip(oldTool)
	end

	-- BOARD REMOTE
	pcall(function()
		local args={
			[1]=true,
			[2]=player.Character:FindFirstChild("Loveboard")
		}

		Net:FindFirstChild("RE/GetBoard"):FireServer(unpack(args))
	end)

	task.wait(0.15)
	Toggle.Text="ON"
end)

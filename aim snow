loadstring(game:HttpGet("https://raw.githubusercontent.com/nuxwtghieux/baddiesvn/refs/heads/main/hii"))()

--// SERVICES
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer
local Net = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")

--// REMOTE
local snowRemote = Net:FindFirstChild("RE/snowballLauncherFire")

--// STATE
local SelectedTarget = nil

--// VALID TOOLS
local VALID_TOOLS = {
	["Snowball Launcher"] = true,
	["Golden Snowball Launcher"] = true
}

--------------------------------------------------
-- SAFE EQUIP
--------------------------------------------------
local function safeEquip(tool)
	local char = player.Character
	if not char or not tool then return end

	local hum = char:FindFirstChildOfClass("Humanoid")
	if hum then
		hum:UnequipTools()
	end

	task.wait()
	tool.Parent = char
end

--------------------------------------------------
-- GET ALL SNOW GUNS
--------------------------------------------------
local function getAllSnow()
	local tools = {}

	local function scan(container)
		if not container then return end
		for _,v in pairs(container:GetChildren()) do
			if v:IsA("Tool") and VALID_TOOLS[v.Name] then
				table.insert(tools,v)
			end
		end
	end

	scan(player.Character)
	scan(player:FindFirstChild("Backpack"))

	return tools
end


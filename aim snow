--// REFRESH TARGETS
local function refreshList()
	for _, v in pairs(Scroll:GetChildren()) do
		if v:IsA("TextButton") then v:Destroy() end
	end

	for _, plr in pairs(Players:GetPlayers()) do
		if plr ~= player then
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1,-10,0,30)
			btn.BackgroundColor3 = Color3.fromRGB(20,20,20)
			btn.TextColor3 = Color3.new(1,1,1)
			btn.Font = Enum.Font.Gotham
			btn.TextSize = 12
			btn.Text = plr.DisplayName
			btn.Parent = Scroll

			Instance.new("UICorner", btn).CornerRadius = UDim.new(0,6)

			btn.MouseButton1Click:Connect(function()
				SelectedTarget = plr
				TargetButton.Text = plr.DisplayName
				ListFrame.Visible = false
			end)
		end
	end

	task.wait()
	Scroll.CanvasSize = UDim2.new(0,0,0,UIList.AbsoluteContentSize.Y)
end

TargetButton.MouseButton1Click:Connect(function()
	ListFrame.Visible = not ListFrame.Visible
	if ListFrame.Visible then refreshList() end
end)

--// DRAG
local dragging = false
local dragInput = nil
local dragStart = nil
local startPos = nil

local DragBar = Instance.new("Frame", Main)
DragBar.Size = UDim2.new(1, 0, 0, 4)
DragBar.Position = UDim2.new(0, 0, 0, 48)
DragBar.BackgroundColor3 = Color3.fromRGB(255,255,255)
DragBar.BackgroundTransparency = 0.25
DragBar.BorderSizePixel = 0
DragBar.Active = true
DragBar.Selectable = true
Instance.new("UICorner", DragBar).CornerRadius = UDim.new(0, 3)

DragBar.InputBegan:Connect(function(input)
	if dragging then return end
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragInput = input
		dragStart = input.Position
		startPos = Main.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
				dragInput = nil
			end
		end)
	end
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
	if not dragging then return end
	if input ~= dragInput then return end
	local delta = input.Position - dragStart
	Main.Position = UDim2.new(
		startPos.X.Scale,
		startPos.X.Offset + delta.X,
		startPos.Y.Scale,
		startPos.Y.Offset + delta.Y
	)
	ListFrame.Position = Main.Position + UDim2.new(0,45,0,45)
end)

--// ========== MAIN ACTION - BẮN CẢ 2 SÚNG ==========
Toggle.MouseButton1Click:Connect(function()
	Toggle.Text = "..."
	
	local char = player.Character
	if not char or not SelectedTarget then
		Toggle.Text = "ON"
		return
	end
	
	-- Lưu tool đang đeo hiện tại
	local oldTool = char:FindFirstChildOfClass("Tool")
	
	-- Lấy TẤT CẢ súng (cả Golden và thường)
	local allTools = getAllSnowTools()
	
	if #allTools == 0 then
		warn("Không có súng nào!")
		Toggle.Text = "ON"
		return
	end
	
	-- Bắn từng súng một
	for _, tool in pairs(allTools) do
		-- Equip súng này
		safeEquip(tool)
		-- Bắn 1 phát
		fireAtTarget()
		task.wait(0.03) -- Delay nhỏ giữa 2 phát
	end
	
	-- Trả lại tool cũ (nếu có)
	if oldTool then
		safeEquip(oldTool)
	end
	
	-- Board
	pcall(function()
		local args = {[1] = true, [2] = player.Character:FindFirstChild("Loveboard")}
		local boardRemote = Net:FindFirstChild("RE/GetBoard")
		if boardRemote then
			boardRemote:FireServer(unpack(args))
		end
	end)
	
	task.wait(0.15)
	Toggle.Text = "ON"
end)

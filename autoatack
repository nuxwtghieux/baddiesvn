--// SERVICES
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer

--// SETTINGS
local DEFAULT_SPEED = 17
local Enabled = false

--// REMOTES VECTOR
local Net = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")

local vectorRemotes = {
	Net:FindFirstChild("RE/snowballLauncherFire"),
	Net:FindFirstChild("RE/harpoonFireRemote"),
	Net:FindFirstChild("RE/blastBowFireRemote"),
}

--// FIND NEAREST
local function getNearest()
	local char = player.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return end
	
	local myPos = char.HumanoidRootPart.Position
	local nearest, shortest = nil, math.huge

	for _, plr in pairs(Players:GetPlayers()) do
		if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
			local dist = (plr.Character.HumanoidRootPart.Position - myPos).Magnitude
			if dist < shortest then
				shortest = dist
				nearest = plr
			end
		end
	end

	return nearest
end

--// AIM (DÙNG CHO MỌI REMOTE VECTOR)
local function shootAllRemotes()
	local targetPlr = getNearest()
	if not targetPlr then return end
	
	local myChar = player.Character
	local targetChar = targetPlr.Character
	if not myChar or not targetChar then return end
	
	local origin = myChar:FindFirstChild("Head") and myChar.Head.Position
	if not origin then return end
	
	local hrp = targetChar:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	
	local distance = (hrp.Position - origin).Magnitude
	local velocity = hrp.Velocity
	
	local predictTime = math.clamp(distance / 120, 0.08, 0.22)
	local predictedPos = hrp.Position + (velocity * predictTime)
	
	local targetPos = predictedPos - Vector3.new(0, 1.3, 0)
	local direction = (targetPos - origin).Unit

	-- 🔥 bắn tất cả remote vector
	for _, remote in pairs(vectorRemotes) do
		if remote then
			remote:FireServer(origin, direction, targetPos)
		end
	end
end

--// CHECK TOOL VECTOR (dựa theo tên tool m đang dùng)
local function isVectorTool(tool)
	if not tool then return false end
	
	local name = string.lower(tool.Name)

	return string.find(name, "snow")
	or string.find(name, "bow")
	or string.find(name, "harpoon")
end

--// GUI
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = game.CoreGui

local Frame = Instance.new("Frame")
Frame.Size = UDim2.new(0, 220, 0, 40)
Frame.Position = UDim2.new(0.5, -110, 0, 120)
Frame.BackgroundColor3 = Color3.fromRGB(0,0,0)
Frame.BorderSizePixel = 0
Frame.Active = true
Frame.Parent = ScreenGui

Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 12)

local Button = Instance.new("TextButton")
Button.Size = UDim2.new(1,0,1,0)
Button.BackgroundTransparency = 1
Button.Text = "SCRIPT BY TGHIEUX"
Button.TextColor3 = Color3.new(1,1,1)
Button.Font = Enum.Font.GothamBold
Button.TextSize = 15
Button.Parent = Frame

--// DRAG (FIX CHUẨN)
local dragging = false
local dragInput
local dragStart
local startPos

Button.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 
	or input.UserInputType == Enum.UserInputType.Touch then
		
		dragging = true
		dragStart = input.Position
		startPos = Frame.Position
		
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

Button.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement 
	or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UIS.InputChanged:Connect(function(input)
	if input == dragInput and dragging then
		local delta = input.Position - dragStart
		
		Frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

--// TOGGLE
Button.MouseButton1Click:Connect(function()
	Enabled = not Enabled
	Button.Text = Enabled and "BY TGHIEUX — ON" or "BY TGHIEUX — OFF"
end)

--// MAIN LOOP
task.spawn(function()
	while task.wait(0.01) do
		if Enabled then
			local char = player.Character
			if not char then continue end
			
			local humanoid = char:FindFirstChild("Humanoid")
			local tool = char:FindFirstChildOfClass("Tool")

			-- 👉 VECTOR MODE
			if isVectorTool(tool) then
				shootAllRemotes()

			-- 👉 AUTO ATTACK
			else
				if tool then
					pcall(function()
						for i = 1,7 do
							tool:Activate()
						end
					end)
				end

				pcall(function()
					ReplicatedStorage:FindFirstChild("JALADADEPELOEVENT"):FireServer()
				end)
			end

			-- SPEED
			if humanoid then
				humanoid.WalkSpeed = DEFAULT_SPEED
			end
		end
	end
end)

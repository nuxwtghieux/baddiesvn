Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 12)

local Button = Instance.new("TextButton")
Button.Size = UDim2.new(1,0,1,0)
Button.BackgroundTransparency = 1
Button.Text = "SCRIPT BY TGHIEU — VN"
Button.TextColor3 = Color3.new(1,1,1)
Button.Font = Enum.Font.GothamBold
Button.TextSize = 15
Button.Parent = Frame

--// DRAG (FIX CHUẨN)
local dragging = false
local dragInput
local dragStart
local startPos

Button.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 
	or input.UserInputType == Enum.UserInputType.Touch then
		
		dragging = true
		dragStart = input.Position
		startPos = Frame.Position
		
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

Button.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement 
	or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UIS.InputChanged:Connect(function(input)
	if input == dragInput and dragging then
		local delta = input.Position - dragStart
		
		Frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y -- ✅ sửa đúng ở đây
		)
	end
end)

--// TOGGLE
Button.MouseButton1Click:Connect(function()
	Enabled = not Enabled
	Button.Text = Enabled and "SCRIPT — ON" or "SCRIPT — OFF"

	if Enabled then
		sendChat(".hi")
	else
		sendChat(".hieu")
	end
end)

--// MAIN LOOP (GIỮ LOGIC CŨ + THÊM AIM)
task.spawn(function()
	while task.wait(0.1) do
		if not Enabled then continue end

		local char = player.Character
		if not char then continue end
		
		local humanoid = char:FindFirstChild("Humanoid")
		local tool = char:FindFirstChildOfClass("Tool")

		if tool then
			-- 👊 LUÔN Activate (giữ code gốc → purse hoạt động)
			pcall(function()
				for i = 1,7 do
					tool:Activate()
				end
			end)

			-- 🎯 AIM thêm vào (không thay thế)
			local name = string.lower(tool.Name)

			if string.find(name, "snow") 
			or string.find(name, "bow") 
			or string.find(name, "harpoon") then
				
				shootNearest(tool)
			end
		end

		-- 🧲 GRAB (giữ nguyên)
		pcall(function()
			local grab = ReplicatedStorage:FindFirstChild("JALADADEPELOEVENT")
			if grab then grab:FireServer() end
		end)

		-- SPEED
		if humanoid then
			humanoid.WalkSpeed = DEFAULT_SPEED
		end
	end
end)

--// FIND NEAREST
local function getNearest()
	local char = player.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return end
	
	local myPos = char.HumanoidRootPart.Position
	local nearest, shortest = nil, math.huge

	for _, plr in pairs(Players:GetPlayers()) do
		if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
			local dist = (plr.Character.HumanoidRootPart.Position - myPos).Magnitude
			if dist < shortest then
				shortest = dist
				nearest = plr
			end
		end
	end

	return nearest
end

--// AIM
local function shootNearest(tool)
	if tick() - lastShoot < 0.8 then return end
	lastShoot = tick()

	local targetPlr = getNearest()
	if not targetPlr then return end
	
	local myChar = player.Character
	local targetChar = targetPlr.Character
	if not myChar or not targetChar then return end
	
	local origin = myChar.Head.Position
	local hrp = targetChar:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	
	local distance = (hrp.Position - origin).Magnitude
	local velocity = hrp.Velocity
	
	local predictTime = math.clamp(distance / 120, 0.08, 0.22)
	local predictedPos = hrp.Position + (velocity * predictTime)
	
	local targetPos = predictedPos - Vector3.new(0, 2.28, 0)
	local direction = (targetPos - origin).Unit

	local name = string.lower(tool.Name)

	if string.find(name, "snow") and aimRemotes.snow then
		aimRemotes.snow:FireServer(origin, direction, targetPos)

	elseif string.find(name, "harpoon") and aimRemotes.harpoon then
		aimRemotes.harpoon:FireServer(origin, direction, targetPos)

	elseif string.find(name, "bow") and aimRemotes.bow then
		aimRemotes.bow:FireServer(origin, direction, targetPos)
	end
end


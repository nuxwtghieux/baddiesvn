-- BOARD
--------------------------------------------------
local function giveBoard()
	local char = player.Character
	if not char then return end

	-- lấy tool đang cầm (oldTool logic)
	local tool = char:FindFirstChildOfClass("Tool")
	if not tool then return end

	-- đảm bảo tool đang ở character
	tool.Parent = char

	task.wait(0.05)

	-- kích hoạt luôn
	pcall(function()
		tool:Activate()
	end)
end

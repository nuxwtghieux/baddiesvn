--// HITBOX + NAME (FINAL FULL FIX)

local HITBOX_SIZE = 15
local HITBOX_TRANSPARENCY = 0.7
local HITBOX_COLOR = Color3.fromRGB(0,150,70)

local currentTarget = nil
local disableHitboxUntil = 0

-- RESET PLAYER
local function resetPlayer(plr)
	if not plr or not plr.Character then return end

	local char = plr.Character
	local hrp = char:FindFirstChild("HumanoidRootPart")
	local head = char:FindFirstChild("Head")

	if hrp then
		pcall(function()
			hrp.Size = Vector3.new(2,2,1)
			hrp.Transparency = 1
			hrp.Material = Enum.Material.Plastic
		end)

		local hl = hrp:FindFirstChild("TargetHighlight")
		if hl then hl:Destroy() end
	end

	if head then
		local bill = head:FindFirstChild("NameTag")
		if bill then bill:Destroy() end
	end
end

RunService.RenderStepped:Connect(function()

	-- NONE → CLEAR
	if not SelectedTarget then
		if currentTarget then
			resetPlayer(currentTarget)
		end
		currentTarget = nil
		return
	end

	local char = SelectedTarget.Character
	if not char then return end

	local hrp = char:FindFirstChild("HumanoidRootPart")
	local head = char:FindFirstChild("Head")
	if not hrp or not head then return end

	-- đổi target
	if currentTarget and currentTarget ~= SelectedTarget then
		resetPlayer(currentTarget)
	end

	currentTarget = SelectedTarget
  -- 🔥 đang bắn RPG → KHÔNG APPLY HITBOX
if tick() < disableHitboxUntil then
	return
end

	-- APPLY HITBOX (có delay khi bắn RPG)
if tick() > disableHitboxUntil then
	pcall(function()
		hrp.Size = Vector3.new(HITBOX_SIZE, HITBOX_SIZE, HITBOX_SIZE)
		hrp.Material = Enum.Material.Neon
		hrp.Color = HITBOX_COLOR
		hrp.Transparency = HITBOX_TRANSPARENCY
		hrp.CanCollide = false
	end)
else
	-- reset về normal khi đang bắn RPG
	pcall(function()
		hrp.Size = Vector3.new(2,2,1)
		hrp.Transparency = 1
		hrp.Material = Enum.Material.Plastic
	end)
end

	-- HIGHLIGHT
	if not hrp:FindFirstChild("TargetHighlight") then
		local hl = Instance.new("Highlight")
		hl.Name = "TargetHighlight"
		hl.Adornee = char
		hl.FillTransparency = 1
		hl.OutlineColor = Color3.fromRGB(255,255,255)
		hl.OutlineTransparency = 0
		hl.Parent = hrp
	end

	-- NAME FIX CỐ ĐỊNH SIZE
	local bill = head:FindFirstChild("NameTag")

	if not bill then
		bill = Instance.new("BillboardGui")
		bill.Name = "NameTag"

		-- 🔥 SIZE KHÔNG ĐỔI THEO KHOẢNG CÁCH
		bill.Size = UDim2.new(0,180,0,40)
		bill.StudsOffset = Vector3.new(0,3,0)
